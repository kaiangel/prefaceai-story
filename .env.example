# ==============================
# 序话Story 环境变量模板
# 复制为 .env 并填入真实值
# ==============================

# --- 必需：AI API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- 必需：火山引擎 TTS ---
# VOLCENGINE_APP_ID       = TTS AppID（控制台 → 语音合成 → 应用管理）
# VOLCENGINE_ACCESS_KEY   = Access Token（Bearer Auth，TTS HTTP API 直接使用）
# VOLCENGINE_API_KEY      = API Key（控制台 → 访问控制 → API Key，供签名鉴权备用）
# VOLCENGINE_SECRET_KEY   = Secret Key（控制台 → 访问控制 → API Key，供签名鉴权备用）
VOLCENGINE_APP_ID=your_volcengine_app_id_here
VOLCENGINE_ACCESS_KEY=your_volcengine_access_token_here
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_SECRET_KEY=your_volcengine_secret_key_here
VOLCENGINE_RESOURCE_ID=volcano_tts
VOLCENGINE_DEFAULT_VOICE=zh_female_shuangkuaisisi_moon_bigtts

# --- 数据库（必须使用 MySQL，不允许 SQLite） ---
# 二选一：
# 1) 直接提供完整 DATABASE_URL（mysql+asyncmy://...）
# 2) 或者填写下面的 MYSQL_*，系统会自动拼装 mysql+asyncmy 连接串
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=prefacestory

# --- 服务器 ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- 存储路径 ---
IMAGE_STORAGE_PATH=./storage/images
AUDIO_STORAGE_PATH=./storage/audio

# --- 图像生成 ---
IMAGE_MAX_CONCURRENT=3
IMAGE_GENERATION_TIMEOUT=120

# --- 图像生成 Provider（2026-05-09 Founder 决定 Seedream 全栈主力）---
# "seedream" → Seedream 5.0-lite 火山方舟国内版（**默认主力**，成本省 55%，2048×2048）
# "nb2"      → Nano Banana 2（保留备用 / Premium 储备 / 回滚预案）
# Seedream 必填 ARK_API_KEY；NB2 必填 GEMINI_API_KEY
IMAGE_GEN_PROVIDER=seedream
# IMAGE_GEN_PROVIDER=nb2  # 切回 NB2 时（保留为 Premium 选项 / 回滚）

# 火山方舟 Ark API Key — IMAGE_GEN_PROVIDER=seedream 时必填
# 创建位置：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=

# --- 分镜拆分 ---
SHOT_MAX_NARRATION_LENGTH=60
SHOT_TARGET_LENGTH=40
SHOT_MIN_LENGTH=25
TTS_CHARS_PER_SECOND=4.0

# --- Mureka AI 音乐生成 ---
MUREKA_API_KEY=op_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
